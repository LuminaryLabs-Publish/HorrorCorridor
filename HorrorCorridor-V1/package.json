    "validate:ceiling-fracture": "node scripts/horror-corridor-live-player-harness.mjs --start-server --browser-executable '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --browser-engine chromium --headed --url 'http://localhost:3000/?debug=frames&liveAgent=1' --action-profile ceiling-fracture --action-duration-ms 300 --artifact-dir docs/live-player-harness/ceiling-fracture-proof",

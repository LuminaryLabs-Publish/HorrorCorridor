    "validate:wet-reflection": "node scripts/horror-corridor-live-player-harness.mjs --start-server --browser-executable '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --browser-engine chromium --headed --url 'http://localhost:3000/?debug=frames&liveAgent=1' --action-profile wet-reflection --action-duration-ms 600 --artifact-dir docs/live-player-harness/wet-reflection-proof",
    "validate:floor-material": "node scripts/horror-corridor-live-player-harness.mjs --start-server --browser-executable '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --browser-engine chromium --headed --url 'http://localhost:3000/?debug=frames&liveAgent=1' --action-profile floor-material --action-duration-ms 350 --artifact-dir docs/live-player-harness/floor-material-proof",
    "validate:success-path": "node scripts/horror-corridor-live-player-harness.mjs --start-server --browser-executable '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --browser-engine chromium --headed --action-profile success-path --artifact-dir docs/live-player-harness/success-path-proof",
    "validate:restart-after-caught": "node scripts/horror-corridor-live-player-harness.mjs --start-server --browser-executable '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --browser-engine chromium --headed --action-profile restart-after-caught --artifact-dir docs/live-player-harness/restart-after-caught-proof",
